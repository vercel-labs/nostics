{
  "name": "logs-sdk",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Structured diagnostic code library",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "contributors": [
    "Eduardo San Martin Morote <posva13@gmail.com>"
  ],
  "license": "MIT",
  "homepage": "https://github.com/vercel-labs/logs-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/logs-sdk.git"
  },
  "bugs": "https://github.com/vercel-labs/logs-sdk/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./dev-reporter": "./dist/dev-reporter.mjs",
    "./formatters/ansi": "./dist/formatters/ansi.mjs",
    "./formatters/json": "./dist/formatters/json.mjs",
    "./node-reporter": "./dist/node-reporter.mjs",
    "./unplugin": "./dist/unplugin.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "vitest",
    "play": "pnpm -C playground run dev",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "node scripts/release.ts",
    "test": "pnpm run build && pnpm -r run build && tsc && eslint && vitest run",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "magic-string": ">=0.30.0",
    "oxc-parser": ">=0.50.0",
    "unplugin": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "magic-string": {
      "optional": true
    },
    "oxc-parser": {
      "optional": true
    },
    "unplugin": {
      "optional": true
    }
  },
  "dependencies": {
    "magic-string": "catalog:deps",
    "oxc-parser": "catalog:deps",
    "unplugin": "catalog:deps"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@antfu/utils": "catalog:inlined",
    "@posva/prompts": "catalog:cli",
    "@types/node": "catalog:types",
    "@types/semver": "catalog:types",
    "bumpp": "catalog:cli",
    "conventional-changelog": "catalog:cli",
    "conventional-changelog-angular": "catalog:cli",
    "esbuild": "catalog:",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "logs-sdk": "workspace:*",
    "publint": "catalog:cli",
    "semver": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsnapi": "catalog:testing",
    "typescript": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
