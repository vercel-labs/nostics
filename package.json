{
  "name": "nostics",
  "type": "module",
  "version": "0.2.0",
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "description": "Structured diagnostic code library",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "contributors": [
    "Eduardo San Martin Morote <posva13@gmail.com>"
  ],
  "license": "MIT",
  "homepage": "https://github.com/vercel-labs/nostics#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/nostics.git"
  },
  "bugs": "https://github.com/vercel-labs/nostics/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./dev": "./dist/dev.mjs",
    "./formatters/ansi": "./dist/formatters/ansi.mjs",
    "./formatters/json": "./dist/formatters/json.mjs",
    "./lib": "./dist/lib.mjs",
    "./reporters/dev": "./dist/reporters/dev.mjs",
    "./reporters/fetch": "./dist/reporters/fetch.mjs",
    "./reporters/node": "./dist/reporters/node.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "vitest",
    "play": "pnpm -C playground run dev",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "node scripts/release.ts",
    "test": "pnpm run build && pnpm -r run build && tsc && eslint && vitest run --coverage",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "magic-string": "catalog:deps",
    "oxc-parser": "catalog:deps",
    "unplugin": "catalog:deps"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@antfu/utils": "catalog:inlined",
    "@posva/prompts": "catalog:cli",
    "@types/node": "catalog:types",
    "@types/semver": "catalog:types",
    "@vitest/coverage-v8": "catalog:testing",
    "@vitest/ui": "catalog:testing",
    "conventional-changelog": "catalog:cli",
    "conventional-changelog-angular": "catalog:cli",
    "esbuild": "catalog:cli",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "nostics": "workspace:*",
    "oxfmt": "catalog:cli",
    "publint": "catalog:cli",
    "semver": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsnapi": "catalog:testing",
    "typescript": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
